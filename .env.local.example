# ─────────────────────────────────────────────────────────────
# VexVor Environment Variables — copy to .env.local and fill in
# NEVER commit .env.local to version control
# ─────────────────────────────────────────────────────────────

# ── Clerk Authentication ─────────────────────────────────────
# Get these from https://dashboard.clerk.com → Your App → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxx

# Clerk redirect paths (keep as-is)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── Application Webhook (optional) ───────────────────────────
# POST target when someone submits the Apply form
# Can be a Zapier/Make webhook, Notion API endpoint, etc.
APPLY_WEBHOOK_URL=

# ── Email (optional — Resend recommended) ───────────────────
# https://resend.com
RESEND_API_KEY=

# ── App URL ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
